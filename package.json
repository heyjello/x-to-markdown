{
  "name": "x-to-markdown",
  "version": "0.1.0",
  "description": "Convert X (Twitter) posts, threads, and X Articles into markdown using the official X API v2.",
  "type": "module",
  "bin": {
    "x-to-markdown": "scripts/main.ts"
  },
  "files": [
    "scripts/",
    "SKILL.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit --strict --target es2022 --module nodenext --moduleResolution nodenext --skipLibCheck --types node scripts/*.ts",
    "start": "bun scripts/main.ts"
  },
  "keywords": [
    "twitter",
    "x",
    "markdown",
    "x-api",
    "claude-skill",
    "tweet",
    "thread",
    "article"
  ],
  "author": "heyjello",
  "license": "MIT",
  "homepage": "https://github.com/heyjello/x-to-markdown",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/heyjello/x-to-markdown.git"
  },
  "bugs": {
    "url": "https://github.com/heyjello/x-to-markdown/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
