{
  "name": "x-to-markdown",
  "version": "0.1.0",
  "description": "Claude and Codex skill to convert X/Twitter posts, threads, and X Articles into Markdown using the official X API v2.",
  "type": "module",
  "files": [
    "scripts/",
    "agents/",
    "SKILL.md",
    "README.md",
    "CHANGELOG.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit --strict --target es2022 --module nodenext --moduleResolution nodenext --skipLibCheck --types node scripts/*.ts",
    "start": "bun scripts/main.ts"
  },
  "keywords": [
    "twitter",
    "x",
    "markdown",
    "x-api",
    "x-api-v2",
    "claude-skill",
    "codex-skill",
    "agent-skills",
    "ai-agent",
    "claude-code",
    "openai-codex",
    "tweet",
    "thread",
    "article",
    "x-articles",
    "obsidian",
    "pkm",
    "content-archiving"
  ],
  "author": "heyjello",
  "license": "MIT",
  "homepage": "https://github.com/heyjello/x-to-markdown",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/heyjello/x-to-markdown.git"
  },
  "bugs": {
    "url": "https://github.com/heyjello/x-to-markdown/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
